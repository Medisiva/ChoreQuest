{
  "expo": {
    "name": "ChoreQuest",
    "slug": "chorequest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "chorequest",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A3E6E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chorequest.app",
      "deploymentTarget": "16.0",
      "infoPlist": {
        "NSCameraUsageDescription": "ChoreQuest needs camera access to take photo proof of completed tasks.",
        "NSPhotoLibraryUsageDescription": "ChoreQuest needs photo library access to attach proof of completed tasks."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A3E6E",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.chorequest.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image",
      [
        "expo-camera",
        {
          "cameraPermission": "ChoreQuest needs camera access to take photo proof of completed tasks."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ChoreQuest needs photo library access to attach proof of completed tasks."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1A3E6E"
        }
      ]
    ]
  }
}
